# Repository list (comma-separated, supports hyphens)
MONITORED_REPOS=facebook/react,vuejs/vue,sveltejs/svelte,tailwindlabs/tailwindcss

# SMTP settings (for local testing only - use GitHub Secrets in Actions)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_RECIPIENT=your-email@gmail.com
